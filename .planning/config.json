{
  "version": "1.0",
  "created": "2026-03-25",
  "project": "Portfolio Engineering Excellence",

  "workflow": {
    "commitStyle": "conventional-commits",
    "commitLanguage": "pt-br",
    "commitsPerPhase": "multiple",
    "commitGranularity": "one-per-logical-group",
    "branchStrategy": "main-direct"
  },

  "verification": {
    "afterEachCommitGroup": ["npm run build", "npx astro check"],
    "afterPhase1": ["npm run build", "npx astro check"],
    "afterPhase2Plus": ["npm run build", "npx astro check", "npm test"],
    "afterLintSetup": ["npm run lint", "npm run build", "npx astro check", "npm test"]
  },

  "research": {
    "enabled": false,
    "reason": "Codebase is known and fully mapped; work is concrete execution"
  },

  "phases": {
    "total": 6,
    "order": "sequential",
    "canSkip": false
  },

  "outOfScope": [
    "New resume content or sections",
    "CMS integration",
    "Contact form or dynamic features",
    "Visual redesign",
    "Docker/containerization"
  ],

  "dependencies": {
    "upgradeAll": true,
    "targets": {
      "astro": "^6.x",
      "typescript": "^6.x",
      "@astrojs/svelte": "^8.x"
    }
  }
}
